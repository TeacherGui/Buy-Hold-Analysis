# --- Issue 4: Data Visualization and Performance Reporting ---

# --- 1. Cumulative Performance Chart ---
# Highlights the portfolio growth against market and macro benchmarks
plt.style.use('seaborn-v0_8-whitegrid')
fig, ax = plt.subplots(figsize=(12, 6))

# Plotting with visual hierarchy: bold for portfolio, subtle for benchmarks
df_comparison['My Portfolio'].plot(ax=ax, color='navy', linewidth=3, label='My Portfolio')
df_comparison['Ibovespa'].plot(ax=ax, color='gray', linewidth=1.5, alpha=0.6, label='Ibovespa')
df_comparison['SELIC (CDI)'].plot(ax=ax, color='green', linewidth=1.5, alpha=0.6, linestyle='--', label='SELIC (CDI)')
df_comparison['IPCA (Inflation)'].plot(ax=ax, color='red', linewidth=1.5, alpha=0.6, linestyle=':', label='IPCA (Inflation)')

plt.title("Cumulative Performance Comparison (Base 100)", fontsize=15, fontweight='bold', pad=20)
plt.ylabel("Growth Index")
plt.xlabel("Date")
plt.axhline(y=100, color='black', linewidth=1, alpha=0.5) # Reference line
plt.legend(frameon=True, facecolor='white', shadow=True)
plt.tight_layout()
plt.show()

# --- 2. Asset Correlation Heatmap ---
# Visualizes diversification efficiency using a triangular matrix
mask = np.triu(np.ones_like(correlation_matrix, dtype=bool))
plt.figure(figsize=(10, 8))

sns.heatmap(correlation_matrix, 
            mask=mask, 
            annot=True, 
            fmt=".2f", 
            cmap='coolwarm', 
            center=0,
            square=True,
            linewidths=.5)

plt.title("Asset Correlation Matrix", fontsize=14, fontweight='bold', pad=15)
plt.tight_layout()
plt.show()

# --- 3. Portfolio Drawdown Chart ---
# Visualizes risk by shading the intensity and duration of declines from peaks
fig, ax = plt.subplots(figsize=(12, 5))

# Plotting the 'underwater' area
drawdown.plot(ax=ax, color='darkred', linewidth=1, label='Drawdown')
ax.fill_between(drawdown.index, drawdown, 0, color='red', alpha=0.3)

# Metrics Annotation
plt.title("Portfolio Drawdown Intensity", fontsize=14, fontweight='bold')
plt.ylabel("Decline (%)")
plt.xlabel("Date")

# Marking the absolute maximum drawdown
plt.axhline(y=max_drawdown, color='black', linestyle='--', alpha=0.5)
# Dynamic positioning for the text label to avoid overlapping
plt.text(drawdown.index[len(drawdown)//2], max_drawdown, f" Max Drawdown: {max_drawdown:.2%}", 
         va='top', fontweight='bold', color='black')

plt.tight_layout()
plt.show()
